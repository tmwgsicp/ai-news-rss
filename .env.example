# AI News RSS - 开源版配置文件
# 使用方法: cp .env.example .env

# ==================== 必需配置 ====================

# AI 分析（智谱 GLM）- 必需！
# 申请地址: https://open.bigmodel.cn/
GLM_API_KEY=your_glm_api_key_here
GLM_MODEL=glm-4-flashx
GLM_TEMPERATURE=0.3

# ==================== 可选配置 ====================

# 数据目录（默认 ./data）
DATA_DIR=./data

# 服务配置
PORT=8000
HOST=0.0.0.0
DEBUG=false

# 定时抓取配置
POLLER_MODE=daily
POLLER_HOUR=7
POLLER_MINUTE=30

# 新闻抓取源（可选，不配置则使用免费源）
# Reddit API (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# GitHub Access Token (https://github.com/settings/tokens)
GITHUB_ACCESS_TOKEN=

# TTS 语音播报（可选）
# 申请地址: https://platform.minimaxi.com/
TTS_ENABLED=false
MINIMAX_API_KEY=

# Webhook 通知（可选 - 企业微信/钉钉等）
# 支持在新闻聚合完成时发送通知
WEBHOOK_URL=
WEBHOOK_NOTIFICATION_INTERVAL=300

# 邮件通知（可选 - 简化版单 SMTP）
# 可在日报生成后发送邮件通知
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# 通知接收邮箱（留空则不发送）
NOTIFICATION_EMAIL=

# RSS 配置
RSS_TITLE=AI News RSS
RSS_DESCRIPTION=AI 行业新闻聚合
RSS_BASE_URL=http://localhost:8000
