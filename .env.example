# AI News RSS - 开源版配置示例
# 复制此文件为 .env 并填入你的配置: cp .env.example .env

# ========== 必填配置 ==========

# AI 分析（智谱 GLM）- 必须配置
# 获取地址: https://open.bigmodel.cn/
GLM_API_KEY=your_glm_api_key_here
GLM_MODEL=glm-4-flashx
GLM_TEMPERATURE=0.3

# ========== 可选配置 ==========

# 数据目录
DATA_DIR=./data

# 服务配置
PORT=8000
HOST=0.0.0.0
DEBUG=false

# 定时抓取配置
POLLER_MODE=daily
POLLER_HOUR=7
POLLER_MINUTE=30

# TTS 语音播报（可选，需要 MiniMax API）
# 获取地址: https://platform.minimaxi.com/
TTS_ENABLED=false
MINIMAX_API_KEY=

# Reddit API（可选，用于抓取 Reddit 社区讨论）
# 获取地址: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# GitHub API（可选，用于抓取 GitHub Trending）
# 获取地址: https://github.com/settings/tokens
GITHUB_ACCESS_TOKEN=

# RSS 配置
RSS_TITLE=AI News RSS
RSS_DESCRIPTION=AI 行业新闻聚合
RSS_BASE_URL=http://localhost:8000
